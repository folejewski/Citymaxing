# Copy to .env.local and fill in as needed. The app runs fine with none of these set.

# mock | google (google is not implemented yet — leave as mock)
PLACES_PROVIDER=mock

# Only read when PLACES_PROVIDER=google
GOOGLE_PLACES_API_KEY=

# Leave blank to run the LLM engine in mock/fallback mode.
# Get a free-tier key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
